{
  "name": "playwright-test-automation-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Playwright Test Automation Platform — npm-workspaces monorepo (UI + API core; opt-in plugins)",
  "author": "CaslanQA",
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "changeset": "changeset",
    "clean": "tsc -b --clean",
    "commit": "cz",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pack:platform": "npm pack packages/core-template",
    "prepare": "husky",
    "release": "changeset publish",
    "smoke": "node scripts/smoke-scaffold.mjs",
    "version-packages": "changeset version"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "allure-playwright": "^3.10.1",
    "commitizen": "^4.3.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
