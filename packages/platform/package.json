{
  "name": "@pwtap/platform",
  "version": "0.1.1",
  "description": "macOS-first platform seam (paths, shell, device discovery/boot, device lock) for Playwright Test Automation Platform plugins",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caslanqa/test-automation-platform.git",
    "directory": "packages/platform"
  },
  "engines": {
    "node": ">=20.19"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "prepack": "npm run build"
  }
}
